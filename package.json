{
  "name": "kanboard",
  "version": "0.1.0",
  "private": true,
  "description": "Local-only agile taskboard with Redis persistence, CRUD functions, a simple UI, and an MCP server.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/http-server.ts",
    "local": "tsx src/http-server.ts",
    "start": "node dist/http-server.js",
    "mcp": "tsx src/mcp-server.ts",
    "mcp:start": "node dist/mcp-server.js",
    "identity:onboard": "tsx src/scripts/identity-onboard.ts",
    "identity:whoami": "tsx src/scripts/whoami.ts",
    "typecheck": "tsc --noEmit",
    "migrate:up": "tsx src/scripts/migrate.ts up",
    "migrate:down": "tsx src/scripts/migrate.ts down"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@upstash/redis": "^1.35.3",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "fastify": "^5.3.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
